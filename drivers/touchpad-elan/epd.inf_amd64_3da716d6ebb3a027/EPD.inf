[Version]
Signature="$Windows NT$"
Provider=%VenderName%
ClassGUID={4D36E96F-E325-11CE-BFC1-08002BE10318}
Class=Mouse
CatalogFile=EPD.cat
DriverVer=10/31/2022, 31.21.28.2
PnpLockdown=1

[SourceDisksNames]
1=%DiskName%,,,

[SourceDisksFiles]
EPD.inf = 1
EPD.sys = 1
EPDCtrl.exe = 1
EPDCmds.dll = 1
EPDApix.dll = 1
EPDService.exe = 1
LenovoAPI.dll = 1
ETDUn_inst.exe = 1

;----------------------------------------------------------------------------
; Manufacturer Sections
;----------------------------------------------------------------------------
[Manufacturer]
%VenderName%   = ELAN.Mfg, NTamd64.10.0

[ELAN.Mfg.NTamd64.10.0]
%PS2DeviceDesc% 		= ELAN_CS19_Win10_Inst, *LEN0300				; TrackPoint (ELAN)
