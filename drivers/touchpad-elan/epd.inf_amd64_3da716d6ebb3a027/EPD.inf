;----------------------------------------------------------------------------
[EPD_DriverOption_ReadPstFromE1.AddReg]
HKR,"DriverOption",TwoFingerGestureMode,%REG_DWORD%,1			; 1 = Standard, 2 = For Acer
HKR,"DriverOption",ButtonMode,%REG_DWORD%,1				; 1 = Button Combine, 2 = Button Indenpendent
HKR,"DriverOption",ClickPadActiveAreaClickMode,%REG_DWORD%,2		; 1 = No Function, 2 = Left Button , 3 = Right Button, 4 = Middle Button
HKR,"DriverOption",ClickPadRestingAreaClickMode,%REG_DWORD%,3		; 1 = No Function, 2 = Left Button , 3 = Right Button, 4 = Middle Button
HKR,"DriverOption",ClickPadGestureAreaTimerMode,%REG_DWORD%,1		; 1 = Timer Check MultiFinger Gesture, 2 = Always MultiFinger Gesture
HKR,"DriverOption",DualModePSTSupportZaxis,%REG_DWORD%,0		; 0 = Not support, 1 = Support
HKR,"DriverOption",AlwaysTrigerScrollFromUserMode,%REG_DWORD%,0		; 0 = Auto, 1 = Always User Mode
HKR,"DriverOption",PSTWorkAndDisableTouchPadEnable,%REG_DWORD%,1	; 0 = Disable, 1 = Enable
HKR,"DriverOption",PSTWorkAndDisableTouchPadTime,%REG_DWORD%,200	; Unit (ms)
HKR,"DriverOption",PSTWorkAndDisableTouchPadTap,%REG_DWORD%,1
HKR,"DriverOption",EnableClickPadRestingAreaClickMode2F,%REG_DWORD%,0		; 0 = Disable, 1 = Enable
HKR,"DriverOption",ClickPadRestingAreaClickLeftMode2F,%REG_DWORD%,2		; 1 = No Function, 2 = Left Button , 3 = Right Button, 4 = Middle Button
HKR,"DriverOption",ClickPadRestingAreaClickRightMode2F,%REG_DWORD%,3		; 1 = No Function, 2 = Left Button , 3 = Right Button, 4 = Middle Button
HKR,"DriverOption",ClickPadRestingAreaClickLeftRightMode2F,%REG_DWORD%,4	; 1 = No Function, 2 = Left Button , 3 = Right Button, 4 = Middle Button
HKR,"DriverOption",HIDSupportEnable,%REG_DWORD%,0
HKR,"DriverOption",EnableTouchInjection,%REG_DWORD%,0			; 0 = Disable, 1 = Enable
HKR,"DriverOption",DualModePSTModuleType,%REG_DWORD%,225		; 1 = NXP, 2 = STek, 3 = ELAN_3003, 4 = ELAN_3006, 225(0xE1) = Read From E1 Command
HKR,"DriverOption",DetectProtocolPSTOnly,%REG_DWORD%,1

