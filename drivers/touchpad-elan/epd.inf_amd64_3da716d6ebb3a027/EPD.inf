;----------------------------------------------------------------------------
; Install Sections
;----------------------------------------------------------------------------

[DestinationDirs]
DefaultDestDir			= 12	; Driver directory
EPDSys.CopyFiles		= 12	; Driver directory
EPDApp.CopyFiles		= 11	; System32 directory

[EPD_Service_Inst]
DisplayName    = %PS2DeviceDesc%
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 0                  ; SERVICE_ERROR_IGNORE
ServiceBinary  = %12%\EPD.sys
LoadOrderGroup = Pointer Port

[EPD_APP_Service_Inst]
DisplayName    = "ELAN PST Service"
ServiceType    = 0x00000010         ; SERVICE_WIN32_OWN_PROCESS
StartType      = 0x00000002         ; SERVICE_AUTO_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %11%\EPDService.exe
LoadOrderGroup = ProfSvc_Group

;----------------------------------------------------------------------------
; Common File Copy and Registry Operations
;----------------------------------------------------------------------------

[EPDSys.CopyFiles]
EPD.sys,,,0x00000001

[EPDApp.CopyFiles]
EPDService.exe,,,0x00000001
EPDCtrl.exe,,,0x00004000
EPDCmds.dll,,,0x00004000
EPDApix.dll,,,0x00004000
LenovoAPI.dll,,,0x00004000
ETDUn_inst.exe,,,0x00004000

;----------------------------------------------------------------------------
; PS/2 SmartPad
;----------------------------------------------------------------------------
;----------------------------------------------------------------------------

[ELAN_CS19_Win10_Inst]
FeatureScore=F9
Include=msmouse.inf
Needs=PS2_Inst
CopyFiles=EPDSys.CopyFiles,EPDApp.CopyFiles

AddReg=	EPD_System.AddReg,\
		EPD_DeviceInfo.AddReg,\
		EPD_OtherSetting_PSTOnly.AddReg,\
		EPD_HIDMouseIgnore.AddReg,\
		EPD_DriverOption_ReadPstFromE1.AddReg,\
		EPD_PSTUI.AddReg,\
		EPD_PSTDisplay.AddReg,\
		EPD_PSTAPOptimize_9999_Win10.AddReg,\
		EPD_GestureAPHotKey.AddReg,\
		EPD_SmartPadUI_Win10_PSTOnly.AddReg,\
		EPD_UIFunctionOption_MiniportPTP_Storm.AddReg,\
		EPD_ELAN_CS19_STVParameter.AddReg

CopyINF=ETDHSA.inf, EPD_component.inf
		
[ELAN_CS19_Win10_Inst.Services]
Include=msmouse.inf
Needs=PS2_Inst.Services
AddService = EPD,0x00000000, EPD_Service_Inst
AddService = EPDService,0x00000800, EPD_APP_Service_Inst
[ELAN_CS19_Win10_Inst.HW]
AddReg = EPD_AddReg.HW

[ELAN_CS19_Win10_Inst.Wdf]
KmdfService = EPD, PS2Device_WdfSect

[ELAN_CS19_Win10_Inst.Components]
AddComponent = EPD_component,,EPD_Extension_ComponentInstall_Win10

; [ELAN_CS19_Win10_Inst.Software]
; AddSoftware = ELANTrackpointforThinkpad,,ETDComponent_TrackpointAppInstall_Win10

